@model recrutementapp.ViewModels.CreateJobViewModel
@{ ViewData["Title"] = "Post a Job"; }

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card-tf">
      <div class="card-tf-header">
        <span><i class="bi bi-plus-circle me-2 text-primary"></i>Post a New Job Offer</span>
      </div>
      <div class="card-tf-body">
        <form asp-action="Create" method="post">
          @Html.AntiForgeryToken()

          <div class="row g-3">
            <div class="col-12">
              <label asp-for="Title" class="form-label">Job Title *</label>
              <input asp-for="Title" class="form-control" placeholder="e.g. Senior .NET Developer" />
              <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
              <label asp-for="ContractType" class="form-label">Contract Type *</label>
              <select asp-for="ContractType" class="form-select">
                <option value="FullTime">Full Time</option>
                <option value="PartTime">Part Time</option>
                <option value="Freelance">Freelance</option>
                <option value="Internship">Internship</option>
              </select>
            </div>

            <div class="col-md-6">
              <label asp-for="ExpiresAt" class="form-label">Expiry Date</label>
              <input asp-for="ExpiresAt" type="date" class="form-control"
                     value="@DateTime.Now.AddDays(30).ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-6">
              <label asp-for="Location" class="form-label">Location</label>
              <input asp-for="Location" class="form-control" placeholder="e.g. Tunis" />
            </div>

            <div class="col-md-3">
              <label asp-for="SalaryMin" class="form-label">Min Salary (TND)</label>
              <input asp-for="SalaryMin" type="number" class="form-control" placeholder="2000" />
            </div>

            <div class="col-md-3">
              <label asp-for="SalaryMax" class="form-label">Max Salary (TND)</label>
              <input asp-for="SalaryMax" type="number" class="form-control" placeholder="5000" />
            </div>

            <div class="col-12">
              <div class="form-check">
                <input asp-for="IsRemote" class="form-check-input" />
                <label asp-for="IsRemote" class="form-check-label">This is a remote position</label>
              </div>
            </div>

            <!-- Skills -->
            @if (ViewBag.Skills != null)
            {
              <div class="col-12">
                <label class="form-label">Required Skills</label>
                <div class="row g-2">
                  @foreach (var skill in (IEnumerable<recrutementapp.Models.Skill>)ViewBag.Skills)
                  {
                    <div class="col-6 col-md-4 col-lg-3">
                      <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="RequiredSkillIds" value="@skill.Id" id="rs_@skill.Id" />
                        <label class="form-check-label small" for="rs_@skill.Id">@skill.Name</label>
                      </div>
                    </div>
                  }
                </div>
              </div>
            }

            <div class="col-12">
              <label asp-for="Description" class="form-label">Job Description *</label>
              <textarea asp-for="Description" class="form-control" rows="10"
                        placeholder="Describe the role, responsibilities, requirements…"></textarea>
              <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-brand px-5 fw-semibold">
              <i class="bi bi-megaphone me-2"></i>Publish Job
            </button>
            <a asp-controller="Recruiter" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
