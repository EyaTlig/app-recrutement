@model recrutementapp.ViewModels.ApplyViewModel
@{ ViewData["Title"] = "Apply — " + Model.JobTitle; }

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card-tf">
      <div class="card-tf-header">
        <div>
          <div class="fw-bold">@Model.JobTitle</div>
          <div class="text-muted small">@Model.CompanyName</div>
        </div>
        <span class="status-badge status-Pending">Applying</span>
      </div>
      <div class="card-tf-body">
        <form asp-action="Apply" method="post" enctype="multipart/form-data">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="JobOfferId" />
          <input type="hidden" asp-for="JobTitle" />
          <input type="hidden" asp-for="CompanyName" />

          <div class="mb-4">
            <label asp-for="CoverLetter" class="form-label">
              Cover Letter <span class="text-muted small">(optional)</span>
            </label>
            <textarea asp-for="CoverLetter" class="form-control" rows="7"
                      placeholder="Tell the recruiter why you are a great fit for this role…"></textarea>
            <span asp-validation-for="CoverLetter" class="text-danger small"></span>
          </div>

          <div class="mb-4">
            <label asp-for="ResumeFile" class="form-label">
              Resume / CV <span class="text-muted small">(PDF, DOC — optional)</span>
            </label>
            <input asp-for="ResumeFile" type="file" class="form-control" accept=".pdf,.doc,.docx" />
            <span asp-validation-for="ResumeFile" class="text-danger small"></span>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-brand px-4 fw-semibold">
              <i class="bi bi-send me-2"></i>Submit Application
            </button>
            <a asp-action="Details" asp-route-id="@Model.JobOfferId" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
