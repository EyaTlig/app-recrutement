@model recrutementapp.ViewModels.JobDetailViewModel
@{ ViewData["Title"] = Model.Title; }

<div class="row g-4">
  <!-- Left: job detail -->
  <div class="col-lg-8">
    <div class="card-tf mb-4">
      <div class="card-tf-body">
        <div class="d-flex align-items-start gap-3 mb-4">
          <div class="company-logo-placeholder" style="width:56px;height:56px;font-size:1.1rem;border-radius:12px">
            @(Model.CompanyName.Length >= 2 ? Model.CompanyName[..2].ToUpper() : Model.CompanyName.ToUpper())
          </div>
          <div>
            <h4 class="fw-bold mb-1">@Model.Title</h4>
            <div class="text-muted">@Model.CompanyName
              @if (!string.IsNullOrEmpty(Model.CompanyWebsite))
              {
                <a href="@Model.CompanyWebsite" target="_blank" class="ms-2 small"><i class="bi bi-box-arrow-up-right"></i></a>
              }
            </div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
          <span class="job-tag"><i class="bi bi-geo-alt"></i>@(Model.IsRemote ? "Remote" : Model.Location)</span>
          <span class="job-tag"><i class="bi bi-clock"></i>@Model.ContractType</span>
          @if (Model.SalaryMin.HasValue)
          {
            <span class="job-tag"><i class="bi bi-cash"></i>@Model.SalaryMin?.ToString("N0")@(Model.SalaryMax.HasValue ? "–" + Model.SalaryMax?.ToString("N0") : "+") TND</span>
          }
          <span class="job-tag"><i class="bi bi-calendar3"></i>Posted @((DateTime.UtcNow - Model.CreatedAt).Days)d ago</span>
          @if (Model.ExpiresAt.HasValue)
          {
            <span class="job-tag text-warning"><i class="bi bi-hourglass-split"></i>Expires @Model.ExpiresAt.Value.ToString("MMM dd")</span>
          }
        </div>

        @if (Model.RequiredSkills.Any() || Model.PreferredSkills.Any())
        {
          <div class="mb-4">
            <h6 class="fw-semibold mb-2">Skills</h6>
            <div class="d-flex flex-wrap gap-2">
              @foreach (var s in Model.RequiredSkills)
              {
                <span class="badge" style="background:#eff6ff;color:#1d4ed8;font-size:.8rem;font-weight:500">@s <span style="opacity:.6;font-size:.65rem">required</span></span>
              }
              @foreach (var s in Model.PreferredSkills)
              {
                <span class="badge bg-light text-muted border" style="font-size:.8rem;font-weight:500">@s <span style="opacity:.6;font-size:.65rem">preferred</span></span>
              }
            </div>
          </div>
        }

        <h6 class="fw-semibold mb-3">Job Description</h6>
        <div class="text-muted lh-lg" style="font-size:.9rem">@Html.Raw(Model.Description)</div>
      </div>
    </div>
  </div>

  <!-- Right: apply card -->
  <div class="col-lg-4">
    <div class="card-tf mb-3" style="position:sticky;top:80px">
      <div class="card-tf-body">
        @if (Model.MatchScore.HasValue)
        {
          var cls = Model.MatchScore >= 70 ? "match-high" : Model.MatchScore >= 40 ? "match-medium" : "match-low";
          <div class="text-center mb-4 p-3 rounded-3" style="background:#f9fafb">
            <div class="fw-bold" style="font-size:2rem;color:#111827">@Model.MatchScore%</div>
            <span class="match-badge @cls"><i class="bi bi-lightning-fill"></i>Match Score</span>
            <p class="text-muted small mt-2 mb-0">Based on your profile skills</p>
          </div>
        }

        @if (Model.HasApplied)
        {
          <div class="text-center p-3 rounded-3 mb-3" style="background:#f0fdf4;border:1px solid #bbf7d0">
            <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <p class="fw-semibold mt-2 mb-0 text-success">Already Applied</p>
          </div>
        }
        else if (User.IsInRole("Candidate"))
        {
          <a asp-action="Apply" asp-route-id="@Model.Id" class="btn btn-brand w-100 py-2 fw-semibold mb-3">
            <i class="bi bi-send me-2"></i>Apply Now
          </a>
        }
        else if (!User.Identity!.IsAuthenticated)
        {
          <a asp-controller="Account" asp-action="Login" class="btn btn-brand w-100 py-2 fw-semibold mb-3">
            <i class="bi bi-person me-2"></i>Sign in to Apply
          </a>
        }

        @if (!string.IsNullOrEmpty(Model.CompanyDescription))
        {
          <hr />
          <h6 class="fw-semibold mb-2">About @Model.CompanyName</h6>
          <p class="text-muted small">@Model.CompanyDescription</p>
        }
      </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-left me-1"></i>Back to Jobs</a>
  </div>
</div>
