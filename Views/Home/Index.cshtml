@model IEnumerable<recrutementapp.ViewModels.JobListItemViewModel>
@{ ViewData["Title"] = "Home"; Layout = "_Layout"; }

<!-- Hero -->
<div class="rounded-3 mb-4 p-5 text-white" style="background:linear-gradient(135deg,#1e40af,#2563eb)">
  <div class="row align-items-center">
    <div class="col-lg-7">
      <h1 class="fw-bold mb-2" style="font-size:2rem">Find Your Next Opportunity</h1>
      <p class="mb-4 opacity-75">Browse hundreds of positions from top companies in Tunisia and beyond.</p>
      <form asp-controller="Job" asp-action="Index" method="get" class="d-flex gap-2 flex-wrap">
        <input name="search" class="form-control" style="max-width:320px" placeholder="Job title, keyword…" />
        <button class="btn btn-light fw-semibold px-4"><i class="bi bi-search me-1"></i>Search</button>
      </form>
    </div>
    <div class="col-lg-5 text-center d-none d-lg-block">
      <i class="bi bi-briefcase-fill" style="font-size:8rem;opacity:.2"></i>
    </div>
  </div>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon blue"><i class="bi bi-briefcase"></i></div>
      <div><div class="stat-value">@Model.Count()</div><div class="stat-label">Active Jobs</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon green"><i class="bi bi-building"></i></div>
      <div><div class="stat-value">1+</div><div class="stat-label">Companies</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon amber"><i class="bi bi-people"></i></div>
      <div><div class="stat-value">3+</div><div class="stat-label">Candidates</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon purple"><i class="bi bi-lightning"></i></div>
      <div><div class="stat-value">AI</div><div class="stat-label">Match Scoring</div></div>
    </div>
  </div>
</div>

<!-- Latest jobs -->
<div class="d-flex align-items-center justify-content-between mb-3">
  <h5 class="fw-semibold mb-0">Latest Opportunities</h5>
  <a asp-controller="Job" asp-action="Index" class="btn btn-sm btn-outline-primary">View All <i class="bi bi-arrow-right ms-1"></i></a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
  @foreach (var job in Model)
  {
    <div class="col">
      <div class="job-card">
        <div class="d-flex align-items-start gap-3">
          <div class="company-logo-placeholder">@(job.CompanyName.Length >= 2 ? job.CompanyName[..2].ToUpper() : job.CompanyName.ToUpper())</div>
          <div class="flex-grow-1 min-w-0">
            <a asp-controller="Job" asp-action="Details" asp-route-id="@job.Id" class="job-title d-block">@job.Title</a>
            <span class="job-company">@job.CompanyName</span>
          </div>
        </div>
        <div class="job-meta">
          <span class="job-tag"><i class="bi bi-geo-alt"></i>@(job.IsRemote ? "Remote" : job.Location)</span>
          <span class="job-tag"><i class="bi bi-clock"></i>@job.ContractType</span>
          @if (job.SalaryMin.HasValue)
          {
            <span class="job-tag"><i class="bi bi-cash"></i>@job.SalaryMin?.ToString("N0") TND</span>
          }
        </div>
        <div class="d-flex align-items-center justify-content-between border-top pt-2 mt-auto">
          <span class="text-muted" style="font-size:.75rem">@((DateTime.UtcNow - job.CreatedAt).Days)d ago</span>
          <a asp-controller="Job" asp-action="Details" asp-route-id="@job.Id" class="btn btn-sm btn-brand">View Job</a>
        </div>
      </div>
    </div>
  }
</div>

<!-- CTA -->
@if (!User.Identity!.IsAuthenticated)
{
  <div class="card-tf text-center p-5">
    <h4 class="fw-bold mb-2">Ready to get started?</h4>
    <p class="text-muted mb-4">Create your free account and start applying today.</p>
    <a asp-controller="Account" asp-action="Register" class="btn btn-brand btn-lg px-5">Create Account</a>
  </div>
}
