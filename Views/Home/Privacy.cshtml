@{ ViewData["Title"] = "Privacy Policy"; }

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card-tf card-tf-body">
      <h3 class="fw-bold mb-4">Privacy Policy</h3>
      <p class="text-muted">
        TalentFlow is committed to protecting your personal information and your right to privacy.
        This policy explains how we collect, use, and safeguard your data.
      </p>
      <h5 class="fw-semibold mt-4">Data We Collect</h5>
      <p class="text-muted">We collect information you provide when registering, including your name, email address, professional profile, and resume documents.</p>
      <h5 class="fw-semibold mt-4">How We Use Your Data</h5>
      <p class="text-muted">Your data is used solely to match candidates with job opportunities and facilitate communication between candidates and recruiters.</p>
      <h5 class="fw-semibold mt-4">Data Security</h5>
      <p class="text-muted">Passwords are stored using BCrypt hashing. We do not store plain-text credentials.</p>
      <h5 class="fw-semibold mt-4">Contact</h5>
      <p class="text-muted">For privacy concerns, contact us at privacy@talentflow.tn</p>
    </div>
  </div>
</div>
