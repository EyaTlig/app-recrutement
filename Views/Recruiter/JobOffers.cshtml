@model List<recrutementapp.ViewModels.JobListItemViewModel>
@{ ViewData["Title"] = "My Job Offers"; }

<div class="d-flex justify-content-between align-items-center mb-4">
  <h5 class="fw-semibold mb-0">My Job Offers (@Model.Count)</h5>
  <a asp-controller="Job" asp-action="Create" class="btn btn-brand">
    <i class="bi bi-plus-circle me-2"></i>Post New Job
  </a>
</div>

@if (!Model.Any())
{
  <div class="card-tf text-center py-5 text-muted">
    <i class="bi bi-briefcase" style="font-size:3rem;color:#d1d5db"></i>
    <p class="mt-3 fw-semibold">No job offers yet</p>
    <a asp-controller="Job" asp-action="Create" class="btn btn-brand mt-1">Post Your First Job</a>
  </div>
}
else
{
  <div class="card-tf">
    <div class="table-responsive">
      <table class="table-tf">
        <thead>
          <tr>
            <th>Job Title</th>
            <th>Location</th>
            <th>Type</th>
            <th>Applicants</th>
            <th>Posted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var j in Model)
          {
            <tr>
              <td>
                <div class="fw-semibold">@j.Title</div>
                <div class="text-muted small">@j.CompanyName</div>
              </td>
              <td class="small">@(j.IsRemote ? "Remote" : j.Location)</td>
              <td><span class="job-tag">@j.ContractType</span></td>
              <td>
                <span class="fw-semibold">@j.ApplicationCount</span>
                <span class="text-muted small"> applicant(s)</span>
              </td>
              <td class="text-muted small">@j.CreatedAt.ToString("MMM dd, yyyy")</td>
              <td>
                <div class="d-flex gap-1">
                  <a asp-controller="Recruiter" asp-action="Applications"
                     class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-people me-1"></i>View
                  </a>
                  <form asp-controller="Recruiter" asp-action="CloseJob" method="post"
                        onsubmit="return confirm('Close this job offer?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@j.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-x-circle"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
