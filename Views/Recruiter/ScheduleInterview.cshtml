@model recrutementapp.ViewModels.ScheduleInterviewViewModel
@{ ViewData["Title"] = "Schedule Interview"; }

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card-tf">
      <div class="card-tf-header">
        <span><i class="bi bi-camera-video me-2" style="color:#7c3aed"></i>Schedule Interview</span>
      </div>
      <div class="card-tf-body">
        <form asp-action="ScheduleInterview" method="post">
          @Html.AntiForgeryToken()
          <input asp-for="ApplicationId" type="hidden" />

          <div class="mb-4">
            <label asp-for="ScheduledAt" class="form-label">Date &amp; Time *</label>
            <input asp-for="ScheduledAt" type="datetime-local" class="form-control"
                   value="@Model.ScheduledAt.ToString("yyyy-MM-ddTHH:mm")" />
            <span asp-validation-for="ScheduledAt" class="text-danger small"></span>
          </div>

          <div class="mb-4">
            <label asp-for="MeetingLink" class="form-label">Meeting Link *</label>
            <input asp-for="MeetingLink" class="form-control"
                   placeholder="https://meet.google.com/… or https://zoom.us/j/…" />
            <span asp-validation-for="MeetingLink" class="text-danger small"></span>
            <div class="mt-2 d-flex gap-2 flex-wrap">
              <button type="button" class="btn btn-sm btn-outline-secondary"
                      onclick="document.getElementById('MeetingLink').value='https://meet.google.com/new'">
                <i class="bi bi-camera-video me-1"></i>Google Meet
              </button>
              <button type="button" class="btn btn-sm btn-outline-secondary"
                      onclick="document.getElementById('MeetingLink').value='https://zoom.us/j/0000000000'">
                <i class="bi bi-camera-video me-1"></i>Zoom
              </button>
              <button type="button" class="btn btn-sm btn-outline-secondary"
                      onclick="document.getElementById('MeetingLink').value='https://teams.microsoft.com/l/meetup-join/new'">
                <i class="bi bi-camera-video me-1"></i>Teams
              </button>
            </div>
          </div>

          <div class="mb-4">
            <label asp-for="Notes" class="form-label">
              Notes for Candidate <span class="text-muted small">(optional)</span>
            </label>
            <textarea asp-for="Notes" class="form-control" rows="3"
                      placeholder="e.g. Please prepare a short presentation about your experience…"></textarea>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-brand px-4 fw-semibold">
              <i class="bi bi-send me-2"></i>Schedule &amp; Notify Candidate
            </button>
            <a asp-action="ApplicationDetail" asp-route-id="@Model.ApplicationId"
               class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
